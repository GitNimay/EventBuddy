# Expo SDK: 54 only
# EXPO_PUBLIC_* values are bundled into the mobile client.
# Do not add service role keys, Cloudinary API secrets, or other server-only secrets here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Cloudinary unsigned uploads
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Push notifications
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id

# Server-side Edge Function secrets, if needed later, must not use EXPO_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=server_only_never_commit
# CLOUDINARY_API_SECRET=server_only_never_commit
